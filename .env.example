# Auth provider selection: supabase | stytch
AUTH_PROVIDER=supabase

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Stytch Configuration
STYTCH_PROJECT_ID=project-test-xxx
STYTCH_SECRET=secret-test-xxx

FRONTEND_URL=http://localhost:3001

# Application Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed origins)
# Leave empty for production to disable CORS or specify allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Internal service token for protected machine-to-machine endpoints
INTERNAL_SERVICE_TOKEN=change-me-in-dev
